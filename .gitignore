# Godot 4+ specific ignores
.godot/

# Python / LSP
__pycache__/
*.pyc
godot_lsp_bridge.py

# Temp / swap files
*.tmp
*.swp
*.swo
*~

# Build exports
android/
web/
windows/
linux/
macos/

# Imported assets (Godot reimports from source)
*.import

# Export presets (may contain local paths)
export_presets.cfg

# Translation binaries (generated from .csv)
*.translation
